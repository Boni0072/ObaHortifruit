# Variáveis de ambiente para o projeto Obra360

# Configuração do Firebase Admin SDK
# 1. Vá para o seu Console do Firebase -> Configurações do Projeto -> Contas de Serviço.
# 2. Clique em "Gerar nova chave privada". Um arquivo JSON será baixado.
# 3. Abra o arquivo JSON, copie TODO o seu conteúdo.
# 4. Cole o conteúdo copiado AQUI, em UMA ÚNICA linha, dentro de aspas simples.
FIREBASE_SERVICE_ACCOUNT_KEY='<COLE AQUI O CONTEÚDO DO SEU ARQUIVO JSON DE CHAVE DE SERVIÇO DO FIREBASE>'

# Porta em que o servidor de desenvolvimento irá rodar
PORT=3000